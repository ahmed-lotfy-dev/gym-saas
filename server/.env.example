# Database (Supabase via connection pooling - for runtime)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for migrations - port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# Database SSL (required for Supabase)
DATABASE_SSL=true

# Better Auth
BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
PORT=3001

# Keep-Alive Scheduler
# Supabase pauses after 7 days of inactivity
# Default: 5 days (safe margin of 2 days before pause)
# Override with value in MINUTES (e.g., 7200 = 5 days)
KEEP_ALIVE_INTERVAL_MINUTES=7200

# Expiry check interval in minutes (default: 60 minutes)
EXPIRY_CHECK_INTERVAL_MINUTES=60
